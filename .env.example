# MongoDB connection. If unset, uses Atlas (cluster0.nktmmeq.mongodb.net).
# For local development when Atlas is unreachable (e.g. DNS/network issues), use:
# MONGODB_URI=mongodb://localhost:27017/navi

# Optional: JWT secret (defaults to a dev value if unset)
# JWT_SECRET=your-secret-here

# --- SendGrid (test / placeholder — replace for production) ---
# Create an API key at https://app.sendgrid.com/settings/api_keys
# Verify a single sender: Settings → Sender Authentication
# SENDGRID_API_KEY=SG.replace_with_your_test_or_full_access_key
# SENDGRID_FROM_EMAIL=you@your-verified-domain.com
# SENDGRID_FROM_NAME=NAVI
# Set to true to log emails only (no SendGrid HTTP calls); omit SENDGRID_API_KEY in CI if you want
# MAIL_DRY_RUN=true
