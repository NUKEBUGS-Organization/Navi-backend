# MongoDB connection (required for production / shared Atlas).
# If unset, the API defaults to: mongodb://127.0.0.1:27017/navi (local MongoDB).
#
# Atlas example (mongodb+srv://... from Atlas → Connect → Drivers):
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/navi?appName=Cluster0
#
# If you see: querySrv ECONNREFUSED _mongodb._tcp.cluster0... — SRV DNS is blocked (VPN, firewall, DNS).
# Fix: use another network, allow DNS SRV, or in Atlas use the non-SRV connection string; or run local MongoDB:
# MONGODB_URI=mongodb://127.0.0.1:27017/navi

# Public base URL of this API (no trailing slash). Use in deploy configs / links.
# API_URL=http://localhost:3000

# Optional: JWT secret (defaults to a dev value if unset)
# JWT_SECRET=your-secret-here

# --- Resend (https://resend.com) ---
# API key from Resend dashboard (never commit real keys)
# RESEND_API_KEY=re_xxxxxxxx
# From must use a domain you verified in Resend, or Resend's onboarding sender for tests
# RESEND_FROM_EMAIL=onboarding@resend.dev
# RESEND_FROM_NAME=NAVI
# Set to true to log emails only (no Resend HTTP calls)
# MAIL_DRY_RUN=true

# Email that receives public organization signup form submissions (defaults to Navi@igcollaborative.com if unset).
# SUPER_ADMIN_NOTIFICATION_EMAIL=Navi@igcollaborative.com

# From address for “organization is ready” emails to the new admin (defaults to karaboyce@changewithnavi.com).
# Same domain as RESEND_FROM_EMAIL must be verified in Resend.
# ORG_OWNER_WELCOME_FROM_EMAIL=karaboyce@changewithnavi.com

# Login page base for “organization is ready” emails (no trailing slash). Defaults to production NAVI app.
# Local: FRONTEND_APP_URL=http://localhost:5173
# FRONTEND_APP_URL=https://app.changewithnavi.com

# Forgot-password OTP emails use the same Resend settings as other mail (RESEND_* / MAIL_DRY_RUN).
# With MAIL_DRY_RUN=true, OTPs are logged to the server console instead of being emailed.
